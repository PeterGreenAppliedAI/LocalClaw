{
  "name": "localclaw",
  "version": "0.1.0",
  "description": "Local-model-first agent framework with Router + Specialist architecture",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsdown src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "setup": "tsx src/setup/index.ts",
    "cli": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@mozilla/readability": "^0.6.0",
    "@slack/bolt": "^4.6.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "croner": "^10.0.1",
    "discord.js": "^14.25.1",
    "ffmpeg-static": "^5.3.0",
    "googleapis": "^171.4.0",
    "grammy": "^1.41.0",
    "json5": "^2.2.3",
    "linkedom": "^0.18.12",
    "pdf-parse": "^1.1.4",
    "playwright-core": "^1.58.2",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsdown": "^0.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

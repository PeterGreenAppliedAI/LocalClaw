{
  // LocalClaw Configuration
  // See .env.example for API key environment variables

  timezone: "America/New_York",

  ollama: {
    url: "${OLLAMA_URL}",
    keepAlive: "30m",
  },

  router: {
    model: "phi4:14b",
    timeout: 2000,
    defaultCategory: "chat",
    categories: {
      chat:       { description: "Simple conversation, greetings, opinions, discussing ideas or plans, questions about the owner/user, or anything answerable from context. Use this when the user is TALKING ABOUT a topic, not requesting an action" },
      web_search: { description: "Questions needing current internet information about external topics (NOT about the owner or user)" },
      memory:     { description: "Questions about past conversations or stored info" },
      exec:       { description: "Run commands, edit files, system operations" },
      cron:       { description: "Schedule, list, or manage recurring tasks and heartbeat tasks" },
      message:    { description: "Send messages to other channels/users" },
      website:    { description: "Teaching materials, courses, assignments" },
      task:       { description: "Create, list, update, or complete tasks and to-dos" },
      multi:      { description: "Complex requests needing multiple different tools or multi-step browser interactions" },
      config:     { description: "Edit settings, cron jobs, workspace files, agent configuration" },
      research:   { description: "User is REQUESTING the bot to perform research and produce a report — e.g. 'research AAPL stock', 'analyze the EV market'. NOT when user is just talking about research" },
    },
  },

  specialists: {
    chat: {
      model: "qwen3-coder:30b",
      systemPrompt: "You are a helpful AI assistant. Be concise and natural.",
      maxTokens: 4096,
      temperature: 0.8,
      maxIterations: 1,
      tools: [],
    },
    web_search: {
      model: "qwen3-coder:30b",
      systemPrompt: "You are a web research specialist. ALWAYS use the web_search tool to find information before answering. Use web_fetch to read page content. Use browser for JavaScript-heavy pages that need rendering. Never answer from memory alone — search first.",
      maxTokens: 4096,
      temperature: 0.3,
      maxIterations: 8,
      tools: ["web_search", "web_fetch", "browser", "reason"],
      pipeline: "web_search",
    },
    memory: {
      model: "qwen3-coder:30b",
      systemPrompt: "You are a memory management specialist. When the user asks you to remember something, ALWAYS use memory_save. When asked about past conversations, ALWAYS use memory_search first.",
      maxTokens: 2048,
      temperature: 0.2,
      maxIterations: 5,
      tools: ["memory_search", "memory_get", "memory_save", "knowledge_import"],
      pipeline: "memory",
    },
    exec: {
      model: "qwen3-coder:30b",
      systemPrompt: "You are a command execution specialist. When the user asks you to run a command, ALWAYS use the exec tool. Show the command output in your response.",
      maxTokens: 4096,
      temperature: 0.3,
      maxIterations: 8,
      tools: ["exec", "read_file", "write_file", "code_session", "reason"],
      pipeline: "exec",
    },
    cron: {
      model: "qwen3-coder:30b",
      systemPrompt: "You are a scheduling specialist. Use cron_add/cron_list/cron_remove for recurring tasks. Use heartbeat_add/heartbeat_list/heartbeat_remove for autonomous periodic checks. For cron schedules, use standard 5-field expressions (minute hour day month weekday). Timezone is America/New_York.",
      maxTokens: 2048,
      temperature: 0.2,
      maxIterations: 3,
      tools: ["cron_add", "cron_list", "cron_remove", "heartbeat_add", "heartbeat_list", "heartbeat_remove"],
      pipeline: "cron",
    },
    message: {
      model: "qwen3-coder:30b",
      maxTokens: 2048,
      temperature: 0.5,
      maxIterations: 3,
      tools: ["send_message"],
      pipeline: "message",
    },
    website: {
      model: "qwen3-coder:30b",
      maxTokens: 4096,
      temperature: 0.3,
      maxIterations: 5,
      tools: ["website_query"],
      pipeline: "website",
    },
    multi: {
      model: "qwen3-coder:30b",
      maxTokens: 4096,
      temperature: 0.3,
      maxIterations: 15,
      tools: ["web_search", "web_fetch", "browser", "memory_search", "memory_save", "exec", "send_message", "task_add", "task_list", "task_done", "reason"],
      pipeline: "plan",
    },
    config: {
      model: "qwen3-coder:30b",
      systemPrompt: "You are a configuration specialist. Use cron_edit, workspace_read, workspace_write to manage settings. Always confirm changes after making them.",
      maxTokens: 4096,
      temperature: 0.3,
      maxIterations: 5,
      tools: ["cron_edit", "cron_add", "cron_list", "cron_remove", "workspace_read", "workspace_write"],
    },
    task: {
      model: "qwen3-coder:30b",
      systemPrompt: "You are a task management specialist. Use task_add to create, task_list to show, task_update to modify, task_done to complete, task_remove to delete. Default to showing todo + in_progress.",
      maxTokens: 2048,
      temperature: 0.2,
      maxIterations: 5,
      tools: ["task_add", "task_list", "task_update", "task_done", "task_remove"],
      pipeline: "task",
    },
    research: {
      model: "qwen3-coder:30b",
      systemPrompt: "You are a research production analyst. You produce polished slide decks, not chat responses.",
      maxTokens: 4096,
      temperature: 0.3,
      maxIterations: 20,
      tools: ["web_search", "web_fetch", "code_session", "write_file", "read_file", "reason"],
      pipeline: "research",
    },
  },

  channels: {
    discord: {
      enabled: true,
      token: "${DISCORD_BOT_TOKEN}",
      security: {
        trustedUsers: ["YOUR_DISCORD_USER_ID"],
        restrictedCategories: ["exec", "config"],
        restrictedTools: ["exec", "write_file", "code_session", "workspace_write"],
      },
    },
    telegram: {
      enabled: false,
      token: "${TELEGRAM_BOT_TOKEN}",
    },
    slack: {
      enabled: false,
      token: "${SLACK_BOT_TOKEN}",
      appToken: "${SLACK_APP_TOKEN}",
    },
    gmail: {
      enabled: false,
    },
    msgraph: {
      enabled: false,
      userId: "${MSGRAPH_USER_ID}",
    },
    web: {
      enabled: true,
      port: 3100,
    },
    whatsapp: {
      enabled: false,
      security: {
        allowedCategories: ["chat", "web_search", "memory", "task"],
        blockedTools: ["exec", "write_file", "send_message", "workspace_write"],
      },
    },
  },

  agents: {
    default: "main",
    list: [
      { id: "main", name: "LocalClaw Assistant" },
    ],
    bindings: [],
  },

  memory: {
    backend: "markdown",
    consolidation: {
      enabled: true,
      model: "phi4-mini",
      similarityThreshold: 0.85,
    },
  },
  cron: { enabled: true, store: "data/cron.json" },
  session: {
    transcriptDir: "data/sessions",
    maxHistoryTurns: 100,
    contextSize: 32768,
    recentTurnsToKeep: 6,
  },

  tools: {
    web: {
      search: { provider: "brave" },
      fetch: { maxChars: 30000 },
    },
    exec: {
      security: "allowlist",  // or "docker"
      allowlist: ["ls", "cat", "python3", "node", "git"],
      timeout: 30000,
      sessions: {
        idleTimeoutMs: 300000,
        maxSessions: 3,
      },
      docker: {
        image: "localclaw-sandbox:latest",
        mountMode: "ro",
        memoryLimit: "512m",
        cpuLimit: "1.0",
        networkMode: "none",
      },
    },
    knowledge: {
      maxChunkSize: 800,
      overlapSize: 100,
    },
  },

  reasoning: {
    model: "nemotron-3-nano:30b",
    maxTokens: 8192,
    temperature: 0.6,
  },

  browser: {
    enabled: true,
    headless: true,
  },

  tts: {
    enabled: false,
    url: "${QWEN_TTS_URL}",
    voice: "serena",
    format: "opus",
  },

  stt: {
    enabled: false,
    url: "${WHISPER_URL}",
    model: "whisper-large-v3",
    language: "en",
  },

  heartbeat: {
    enabled: true,
    schedule: "0 */2 * * *",
    delivery: {
      channel: "discord",
      target: "YOUR_DISCORD_USER_ID",
    },
  },

  vision: {
    enabled: false,
    model: "qwen3-vl:8b",
    prompt: "Describe this image in detail.",
    maxTokens: 1024,
  },
}
